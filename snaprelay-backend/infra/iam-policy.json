{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "Logs",
      "Effect": "Allow",
      "Action": ["logs:CreateLogGroup", "logs:CreateLogStream", "logs:PutLogEvents"],
      "Resource": "arn:aws:logs:us-east-1:605151466332:*"
    },
    {
      "Sid": "S3ObjectAccess",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject", "s3:DeleteObject", "s3:HeadObject"],
      "Resource": "arn:aws:s3:::snaprelay-files-605151466332/*"
    },
    {
      "Sid": "S3Bucket",
      "Effect": "Allow",
      "Action": ["s3:ListBucket", "s3:GetBucketLocation"],
      "Resource": "arn:aws:s3:::snaprelay-files-605151466332"
    },
    {
      "Sid": "Dynamo",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:UpdateItem",
        "dynamodb:DeleteItem",
        "dynamodb:Query",
        "dynamodb:Scan",
        "dynamodb:BatchGetItem",
        "dynamodb:BatchWriteItem",
        "dynamodb:TransactWriteItems"
      ],
      "Resource": [
        "arn:aws:dynamodb:us-east-1:605151466332:table/snaprelay-files",
        "arn:aws:dynamodb:us-east-1:605151466332:table/snaprelay-files/index/*",
        "arn:aws:dynamodb:us-east-1:605151466332:table/snaprelay-groups",
        "arn:aws:dynamodb:us-east-1:605151466332:table/snaprelay-memberships",
        "arn:aws:dynamodb:us-east-1:605151466332:table/snaprelay-memberships/index/*",
        "arn:aws:dynamodb:us-east-1:605151466332:table/snaprelay-invites",
        "arn:aws:dynamodb:us-east-1:605151466332:table/snaprelay-shares",
        "arn:aws:dynamodb:us-east-1:605151466332:table/snaprelay-cameras",
        "arn:aws:dynamodb:us-east-1:605151466332:table/snaprelay-cameras/index/*"
      ]
    },
    {
      "Sid": "Transfer",
      "Effect": "Allow",
      "Action": [
        "transfer:CreateUser",
        "transfer:UpdateUser",
        "transfer:DeleteUser",
        "transfer:DescribeUser",
        "transfer:ImportSshPublicKey",
        "transfer:DeleteSshPublicKey",
        "transfer:ListUsers",
        "transfer:DescribeServer"
      ],
      "Resource": [
        "arn:aws:transfer:us-east-1:605151466332:server/*",
        "arn:aws:transfer:us-east-1:605151466332:user/*/*"
      ]
    },
    {
      "Sid": "PassSftpRole",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "arn:aws:iam::605151466332:role/snaprelay-sftp-role",
      "Condition": { "StringEquals": { "iam:PassedToService": "transfer.amazonaws.com" } }
    },
    {
      "Sid": "Sqs",
      "Effect": "Allow",
      "Action": [
        "sqs:ReceiveMessage",
        "sqs:DeleteMessage",
        "sqs:GetQueueAttributes",
        "sqs:ChangeMessageVisibility"
      ],
      "Resource": "arn:aws:sqs:us-east-1:605151466332:snaprelay-processing"
    }
  ]
}
