# ============================================================================
# SnapRelay — single source of truth for all non-secret configuration
#
# Copy this file to .env and fill in real values:   cp .env.example .env
#
# .env is gitignored. Never commit it. Share values out-of-band if a teammate
# needs them.
#
# Consumers:
#   - Next.js frontend reads this via a symlink at snaprelay-frontend/.env.local.
#     (Only NEXT_PUBLIC_* vars are shipped to the browser.)
#   - Lambda deploy scripts source this file and pass values via
#     `aws lambda update-function-configuration --environment`.
#
# AWS developer access keys (yours) do NOT go here.
#   → those live in ~/.aws/credentials (run `aws configure`).
#   Lambdas themselves never use access keys — they authenticate via their
#   IAM execution role.
# ============================================================================

# ---- AWS infrastructure (used by Lambda deploy scripts, not shipped to browser)
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=000000000000
S3_BUCKET=snaprelay-files-000000000000
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/000000000000/snaprelay-processing
SQS_QUEUE_ARN=arn:aws:sqs:us-east-1:000000000000:snaprelay-processing
LAMBDA_EXEC_ROLE_ARN=arn:aws:iam::000000000000:role/snaprelay-lambda-exec

# DynamoDB tables (referenced by Lambdas as env vars)
DYNAMODB_FILES_TABLE=snaprelay-files
DYNAMODB_GROUPS_TABLE=snaprelay-groups
DYNAMODB_MEMBERSHIPS_TABLE=snaprelay-memberships
DYNAMODB_INVITES_TABLE=snaprelay-invites
DYNAMODB_SHARES_TABLE=snaprelay-shares

# ---- Frontend (NEXT_PUBLIC_* = compiled into the browser bundle)
# Safe to expose: these are designed to be public.
NEXT_PUBLIC_USE_MOCK=true
NEXT_PUBLIC_API_URL=https://replace-me.execute-api.us-east-1.amazonaws.com/prod
NEXT_PUBLIC_USER_POOL_ID=us-east-1_XXXXXXXXX
NEXT_PUBLIC_USER_POOL_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_AWS_REGION=us-east-1
